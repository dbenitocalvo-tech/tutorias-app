# Copia este archivo a ".env" y pon ahí los datos de tu proyecto de Supabase
# (Project Settings -> API en https://supabase.com).
#
# La "anon / public key" es segura de usar en el navegador (Supabase la
# diseñó para eso). NUNCA pongas aquí la "service_role" / "secret" key.

VITE_SUPABASE_URL="https://TU-PROYECTO.supabase.co"
VITE_SUPABASE_ANON_KEY="tu-anon-key"
